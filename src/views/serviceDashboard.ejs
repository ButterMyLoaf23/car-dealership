<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="./css/main.css"
</head>
<body>
    <header>
        <%- include("partials/header") %>
    </header>

    <h1>Manage Requests</h1>

    <% request.forEach(request => { %>
        <div>
            <p><strong>Vehicle:</strong><%= request.year %> <%= request.make %> <%= request.model %></p>
            <p><strong>Service:</strong><%= request.service_type %></p>
            <p><strong>Status:</strong><%= request.status %></p>

            <div class="admin-power">
                <form method="POST" action="/service/<%= request.id %>/status">
                    <select name="status">
                        <option>Pending</option>
                        <option>In Progress</option>
                        <option>Completed</option>
                    </select>
                    <button>Update</button>
                </form>

                <a href="/service/<%= request.id %>/edit" class="btn">Edit</a>

                <form method="POST" action="/service/<%= request.id %>/delete">
                    <button onclick="return confirm('Delete this service?')">Delete</button>
                </form>
            </div>
        </div>
    <% }) %>

</body>
</html>