<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Car Dealership</title>
    <link rel="stylesheet" href="./css/main.css">
</head>
    <body>
        <header>
            <%- include("partials/header") %>
        </header>

        <section class="hero">
            <div class="hero-content">
                <h2>Find Your Dream Car Today</h2>
                <p>Best deals this side of the Mississippi</p>
                <a href="/vehicles" class="primary-btn">Browse Inventory</a>
            </div>
        </section>
        <section class="searchbar">
            <select>
                <option>Make</option>
                <option>Toyota</option>
                <option>Honda</option>
                <option>Ford</option>
                <option>GMC</option>
                <option>BMW</option>
            </select>
            
            <select>
                <option>Model</option>
            </select>

            <select>
                <option>Year</option>
            </select>

            <button>Search</button>
        </section>

        <section class="inventory">
            <h2>Featured Vehicles</h2>

            <div class="car-grid">
                <% vehicles.forEach(vehicle => { %>
                    <%- include("partials/car-card", { vehicle: vehicle }) %>
                <% }) %>
            </div>
        </section>
        

        
    </body>
</html>