<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Service Error</title>
</head>
<body>
    <h1>500</h1>

    <p>Something went wrong on our end</p>

    <% if (error) { %>
        <p><strong>Error:</strong> <%= error %></p>
    <% } %>

    <% if (stack) { %>
        <pre><%= stack %></pre>
    <% } %>

    <a href="/">Home</a>
</body>
</html>