<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vehicles</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<header>
    
    <body>

        <%- include("partials/header") %>

        <h1>All Vehicles</h1>

            <form method="GET" action="/vehicles" class="sort-form">
                <select name="sort" onchange="this.form.submit()">
                    <option value="">Sort By</option>
                    <option value="sort-asc">Price: Low --> High</option>
                    <option value="sort-desc">Price: High --> Low</option>
                    <option value="year-asc">Oldest</option>
                    <option value="year-desc">Newest</option>
                </select>
            </form>

        <div class="vehicle-grid">
            <% vehicles.forEach(vehicle => { %>
                <a href="/vehicle/<%= vehicle.id %>" class="vehicle-card">
                    <img src="<%= vehicle.image_url %>" alt="car" />
                    <div class="card-content">
                        <h3><%= vehicle.year %> <%= vehicle.title %></h3>
                    </div>
                    <div class="price">
                        $<%= vehicle.price %>
                    </div>
                </a>
            <% }) %>
        </div>
    </body>
</header>
</html>